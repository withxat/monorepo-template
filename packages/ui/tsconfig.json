{
	"extends": "@withxat/tsconfig",
	"compilerOptions": {
		"jsx": "react-jsx",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"paths": {
			"ui/lib/*": ["./src/lib/*"],
			"ui/hooks/*": ["./src/hooks/*"],
			"ui/icons": ["./src/icons.ts"],
			"ui/sonner": ["./src/sonner.ts"],
			"ui/*": ["./src/components/*"]
		}
	},
	"include": ["src"]
}
